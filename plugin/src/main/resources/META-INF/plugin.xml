<idea-plugin>
    <id>com.onelens.plugin</id>
    <name>OneLens Graph Builder</name>
    <vendor>OneLens</vendor>
    <description><![CDATA[
        Export your Java/Spring Boot project's complete code intelligence to a knowledge graph.
        Uses IntelliJ's PSI APIs for 100% accurate type resolution, call graphs, and Spring bean wiring.
    ]]></description>

    <!-- Required: IntelliJ Platform only. Language / framework support is optional so the
         plugin can install into WebStorm (no Java), PyCharm, and IDEA Community/Ultimate. -->
    <depends>com.intellij.modules.platform</depends>

    <!-- Java / Spring Boot adapter. Loads ExportFullAction, AutoSync for .java, Spring
         collectors. Absent on WebStorm or PyCharm — plugin still installs. -->
    <depends optional="true" config-file="framework-springboot.xml">com.intellij.modules.java</depends>

    <!-- Further Spring-plugin features (Endpoints provider, bean graph APIs) load when the
         com.intellij.spring plugin is present on top of Java. -->
    <depends optional="true" config-file="spring-features.xml">com.intellij.spring</depends>

    <!-- Vue 3 adapter. Requires the JavaScript + Vue plugins; available in WebStorm and
         IDEA Community/Ultimate once installed from Marketplace. -->
    <depends optional="true" config-file="framework-vue3.xml">org.jetbrains.plugins.vue</depends>

    <!-- Git4Idea — enables GitInfo for Publish dialog tag pre-fill. Optional so
         the plugin still loads on WebStorm without Git plugin. -->
    <depends optional="true" config-file="git-features.xml">Git4Idea</depends>

    <!-- Framework adapter extension point. Each language/framework contributes an adapter. -->
    <extensionPoints>
        <extensionPoint name="frameworkAdapter"
                        interface="com.onelens.plugin.framework.FrameworkAdapter"
                        dynamic="true"/>
    </extensionPoints>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
            serviceImplementation="com.onelens.plugin.settings.OneLensSettings"/>
        <projectService
            serviceImplementation="com.onelens.plugin.export.ExportState"/>
        <projectService
            serviceImplementation="com.onelens.plugin.autosync.AutoSyncService"/>
        <projectService
            serviceImplementation="com.onelens.plugin.ui.OneLensStatusService"/>
        <postStartupActivity
            implementation="com.onelens.plugin.autosync.AutoSyncStartupActivity"/>
        <notificationGroup id="OneLens" displayType="BALLOON"/>
        <toolWindow id="OneLens"
                    anchor="right"
                    secondary="false"
                    factoryClass="com.onelens.plugin.ui.OneLensToolWindowFactory"/>
    </extensions>

    <applicationListeners>
        <listener class="com.onelens.plugin.autosync.AutoSyncFileListener"
                  topic="com.intellij.openapi.vfs.newvfs.BulkFileListener"/>
        <!-- BranchChangeListener lives in git-features.xml (optional Git4Idea dep) -->
    </applicationListeners>

    <actions>
        <group id="OneLens.Actions" text="OneLens" popup="true">
            <action id="OneLens.SyncGraph"
                class="com.onelens.plugin.actions.ExportFullAction"
                text="Sync Graph"
                description="Smart sync — auto-detects changes, exports full or delta as needed"/>
            <action id="OneLens.ToggleAutoSync"
                class="com.onelens.plugin.actions.ToggleAutoSyncAction"
                text="Toggle Auto-Sync"
                description="Enable/disable automatic graph sync on file save"/>
            <action id="OneLens.ToggleSemanticIndex"
                class="com.onelens.plugin.actions.ToggleSemanticIndexAction"
                text="Build Semantic Index"
                description="ON = graph + ChromaDB embeddings for NL retrieve (slow first sync). OFF = graph-only, fast, structural queries only."/>
            <action id="OneLens.InstallSkill"
                class="com.onelens.plugin.skill.InstallSkillAction"
                text="Install Skill for Claude Code"
                description="Copy OneLens skill (SKILL.md) to ~/.claude/skills/. Claude Code invokes `onelens` via its Bash tool — no daemon, no MCP."/>
            <action id="onelens.PublishSnapshot"
                class="com.onelens.plugin.actions.PublishSnapshotAction"
                text="Publish Snapshot…"
                description="Bundle the current graph as a release snapshot — local file or GitHub Release upload."/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </group>
    </actions>
</idea-plugin>
