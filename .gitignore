# OneLens local data
.onelens/

# Research/benchmark scratchpads (trial_*.py) — keep locally for reproducing
# embedding-model comparisons, but not part of the shipped code.
python/trial_*.py

# Modal deployment scripts — reference specific graph names, keep local.
python/modal_index*.py

# Benchmark suite — references specific client graph names + FQN ground truth.
# Every developer runs benchmarks against their own indexed project; no single
# cases.yaml is portable. Keep local.
python/benchmarks/

# Environment
.env
.env.local

# OS
.DS_Store
Thumbs.db

