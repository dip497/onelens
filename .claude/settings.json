{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "./.claude/hooks/fmt-python.sh" },
          { "type": "command", "command": "./.claude/hooks/fmt-kotlin.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "./.claude/hooks/changelog-reminder.sh" }
        ]
      }
    ]
  }
}
